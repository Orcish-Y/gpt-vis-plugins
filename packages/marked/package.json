{
  "name": "gpt-vis-marked",
  "version": "0.0.1",
  "description": "A Marked extension to transform GPT-Vis syntax into visualizations",
  "keywords": [
    "marked",
    "markdown",
    "plugin",
    "gpt-vis",
    "antv",
    "visualization",
    "LLM"
  ],
  "homepage": "https://gpt-vis.antv.vision",
  "repository": {
    "type": "git",
    "url": "https://github.com/antvis/gpt-vis-md-plugins",
    "directory": "packages/marked"
  },
  "license": "MIT",
  "author": "antvis",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README-zh.md"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@antv/gpt-vis": "^1.0.0",
    "marked": "^13.0.0 || ^14.0.0 || ^15.0.0"
  },
  "devDependencies": {
    "@antv/gpt-vis": "^1.0.0",
    "marked": "^15.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
